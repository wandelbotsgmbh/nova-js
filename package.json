{
  "name": "@wandelbots/nova-js",
  "type": "module",
  "version": "0.0.0-semantically-released",
  "description": "Official JS client for the Wandelbots API",
  "sideEffects": false,
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./v1": {
      "import": "./dist/v1/index.mjs",
      "require": "./dist/v1/index.cjs"
    },
    "./v2": {
      "import": "./dist/v2/index.mjs",
      "require": "./dist/v2/index.cjs"
    },
    "./experimental/nats": {
      "import": "./dist/experimental/nats/index.mjs",
      "require": "./dist/experimental/nats/index.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "pnpm build && concurrently --names build,app --prefix-colors blue,magenta \"tsdown --watch --no-clean\" \"pnpm --filter example dev\"",
    "dev:pack": "nodemon -w \".\" -e ts -i *.tgz -i dist -x \"pnpm run build && pnpm pack\"",
    "tsc": "concurrently --group --names tsc,tsc:example --prefix-colors blue,magenta \"tsc --pretty --noEmit\" \"pnpm --filter example tsc\"",
    "biome": "biome check --error-on-warnings .",
    "format": "biome format . --write",
    "knip": "knip",
    "build": "tsdown",
    "generate:nats": "node scripts/generate-nats-client.ts && biome format --write src/lib/experimental/nats/generated",
    "test": "pnpm run build && vitest run",
    "e2e": "vitest run --config vitest.e2e.config.ts",
    "checks": "pnpm format && pnpm build && concurrently --group --timings --names audit,biome,tsc,knip,test \"pnpm audit --audit-level high\" \"pnpm biome\" \"pnpm tsc\" \"pnpm knip\" \"vitest run\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wandelbotsgmbh/nova-js.git"
  },
  "keywords": [
    "wandelbots",
    "nova",
    "api"
  ],
  "author": "Wandelbots",
  "license": "Apache-2.0",
  "devDependencies": {
    "@asyncapi/parser": "^3.6.0",
    "@biomejs/biome": "^2.4.16",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "knip": "^6.15.0",
    "lodash-es": "^4.18.1",
    "nodemon": "^3.1.14",
    "semantic-release": "^25.0.3",
    "semantic-release-export-data": "^1.2.0",
    "tsdown": "^0.22.1",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@auth0/auth0-spa-js": "^2.21.0",
    "@nats-io/nats-core": "^3.4.0",
    "@types/three": "^0.183.1",
    "@wandelbots/nova-api": "26.5.0",
    "axios": "^1.16.1",
    "mobx": "^6.15.4",
    "path-to-regexp": "^8.4.2",
    "reconnecting-websocket": "^4.4.0",
    "three": "^0.183.2"
  }
}
